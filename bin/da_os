#!/usr/bin/env zsh
#
#
set -u -e -o pipefail

THIS_SCRIPT="$0"

export ORIGIN_DIR="$PWD"

cd "$(dirname "$THIS_SCRIPT")"/..
export DA_OS_DIR="$PWD"
export ORIGIN_PATH="$PATH"

has() {
  command -v "$1" >/dev/null
}


os_packager="unknown"
os_nickname="unknown"


for NICKNAME in dnf xbps-install apk ; do
  if has "$NICKNAME" ; then
    os_packager="$NICKNAME"
    break
  fi
done

# === Handle special cases:
case "$os_packager" in
  unknown)
    os_nickname="base"
    SUB_PATH="$DA_OS_DIR/$os_nickname"
    ;;
  xbps-install)
    os_nickname="xbps"
    SUB_PATH="$DA_OS_DIR/$os_nickname:$DA_OS_DIR/base"
    ;;
  *)
    os_nickname="$os_packager"
    SUB_PATH="$DA_OS_DIR/$os_nickname:$DA_OS_DIR/base"
    ;;
esac

case "$*" in
  # doc: CMD --help -- Show this message.
  "--help")
    cmd="$(basename "$0")"
    grep -E '# +doc:' "$0" | sed 's/#[[:space:]]\+doc:// ; s/CMD/'${cmd}'/'
    exit 0
    ;;

  # doc: CMD paths -- Prints a PATH= string to use as your new PATH.
  paths)
  echo "$SUB_PATH"
  exit 0
  ;;
esac

# target_os="$(get_os_name)"
# target_family="$(get_os_family)"

# echo "$target_os of $target_family" >&2

PATH="$PATH:$SUB_PATH"
"$@"

