#!/usr/bin/env zsh
#
#
set -u -e -o pipefail

THIS_SCRIPT="$0"

export ORIGIN_DIR="$PWD"

cd "$(dirname "$THIS_SCRIPT")"
cd ..

PATH="$PATH:$PWD/helpers"

case "$*" in
  # doc: CMD -h|--help|help -- Show this message.
  "-h"|"--help"|"help")
    cmd="$(basename "$0")"
    grep -E '# +doc:' "$0" | sed 's/#[[:space:]]\+doc:// ; s/CMD/'${cmd}'/'
    exit 0
    ;;
esac

get_script_name() {
  if test -e "$target_os/$1" ; then
    echo "$target_os/$1"
    return 0
  fi

  if test -e "$target_family/$1" ; then
    echo "$target_family/$1"
    return 0
  fi

  if test -e "all/$1" ; then
    echo "all/$1"
    return 0
  fi

  echo "!!! Script not foundu in $PWD: $1"
  exit 2
}

target_os="$(get_os_name)"
target_family="$(get_os_family)"

case "$1" in
  # doc: CMD user-exists [name]
  'user-exists')
  echo "$target_os" >&2
  script_name="$(get_script_name "$1")"
  "$script_name" da
  ;;

  *)
    echo "!!! Unknown command: $*" >&2
    exit 1
    ;;
esac
